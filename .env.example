APP_NAME="YQL DNA Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Custom flag read in config/app.php -> 'enable_otp'
ENABLE_OTP=false

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=yql_dna_portal
DB_USERNAME=yql_dna_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

# Fill these in with your real SMTP provider (your domain host, Gmail App
# Password, SendGrid, Mailgun, etc.) — until then, contact form emails and
# user invitation emails will not actually be delivered.
# For safe local testing without sending real email, set MAIL_MAILER=log —
# outgoing messages are written to storage/logs/laravel.log instead.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="YQL DNA Portal"

# Used to build the login link in the user-invitation email.
PORTAL_URL=https://portal.my-yql.org
